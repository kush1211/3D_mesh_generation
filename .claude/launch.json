{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "cmd",
      "runtimeArgs": [
        "/c",
        "cd /d frontend && node node_modules\\vite\\bin\\vite.js --port 5173 --strictPort"
